# Web
NEXT_PUBLIC_API_URL=http://localhost:8100

# API
API_ENV=development
API_PORT=8100
CORS_ALLOW_ORIGINS=http://localhost:3300,http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_TTL_SEC=3600
JWT_LEEWAY_SEC=30
MAX_UPLOAD_MB=25
MAX_IMAGE_PIXELS=30000000
RATE_LIMIT_PER_MINUTE=60
REQUEST_LOG_ENABLED=true
ENABLE_READY_CHECKS=true
DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/manga_translate
PIPELINE_QUEUE_NAME=pipeline:jobs
PIPELINE_DEAD_LETTER_QUEUE_NAME=pipeline:jobs:dead-letter
PIPELINE_MAX_ATTEMPTS=3
PIPELINE_JOB_TIMEOUT_SEC=120
PIPELINE_STALE_RUNNING_SEC=180
PIPELINE_RETRY_COUNT=2
PIPELINE_CIRCUIT_FAILURE_THRESHOLD=5
PIPELINE_CIRCUIT_RESET_SEC=60
PROVIDER_REGISTRY_PATH=providers.yaml
MODEL_RUNTIME_DEVICE=auto
DETECTION_YOLO_MODEL_PATH=models/best-3.pt
DETECTION_ALLOWED_LABELS=buble,bubble,text
DETECTION_CONF_THRESHOLD=0.25
DETECTION_IOU_THRESHOLD=0.45
INPAINT_BUBBLE_EXPAND_PX=8
INPAINT_TEXT_EXPAND_PX=3
INPAINT_BUBBLE_SCALE=1.03
INPAINT_TEXT_SCALE=1.0
OCR_LANGUAGES=ja,en
TRANSLATION_MODEL_ID=facebook/nllb-200-distilled-600M
TRANSLATION_SOURCE_LANG=jpn_Jpan
TRANSLATION_BATCH_SIZE=4
TRANSLATION_MAX_INPUT_LENGTH=256
TRANSLATION_MAX_OUTPUT_LENGTH=256

# Infra
POSTGRES_DB=manga_translate
POSTGRES_USER=app
POSTGRES_PASSWORD=app
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=manga-pages
S3_REGION=us-east-1
SIGNED_URL_EXPIRES_SEC=900
