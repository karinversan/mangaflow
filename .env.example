# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# API
API_ENV=development
API_PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ACCESS_TTL_SEC=3600
JWT_LEEWAY_SEC=30
MAX_UPLOAD_MB=25
MAX_IMAGE_PIXELS=30000000
RATE_LIMIT_PER_MINUTE=60
REQUEST_LOG_ENABLED=true
DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/manga_translate
PIPELINE_QUEUE_NAME=pipeline:jobs
PIPELINE_DEAD_LETTER_QUEUE_NAME=pipeline:jobs:dead-letter
PIPELINE_MAX_ATTEMPTS=3
PIPELINE_JOB_TIMEOUT_SEC=120
PIPELINE_RETRY_COUNT=2
PIPELINE_CIRCUIT_FAILURE_THRESHOLD=5
PIPELINE_CIRCUIT_RESET_SEC=60

# Infra
POSTGRES_DB=manga_translate
POSTGRES_USER=app
POSTGRES_PASSWORD=app
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=manga-pages
S3_REGION=us-east-1
SIGNED_URL_EXPIRES_SEC=900
